<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xsi:type="MailApp">
    <Id>6d52d0c3-4d62-4a60-8f74-6e47d5a4a9d2</Id>
    <Version>1.0.0.0</Version>
    <ProviderName>Coopenorte</ProviderName>
    <DefaultLocale>en-US</DefaultLocale>
    <DisplayName DefaultValue="Firma Coopenorte" />
    <Description DefaultValue="Automatically inserts the company signature." />
    <IconUrl DefaultValue="https://legiewia.github.io/icon32.png" />
    <HighResolutionIconUrl DefaultValue="https://legiewia.github.io/icon80.png" />
    <SupportUrl DefaultValue="https://legiewia.github.io" />
    <Hosts>
        <Host Name="Mailbox" />
    </Hosts>
    <Requirements>
        <Sets>
            <Set Name="Mailbox" MinVersion="1.10" />
        </Sets>
    </Requirements>
    <FormSettings>
        <Form xsi:type="ItemEdit">
            <DesktopSettings>
                <SourceLocation DefaultValue="https://legiewia.github.io/event.html" />
            </DesktopSettings>
        </Form>
    </FormSettings>
    <Permissions>ReadWriteItem</Permissions>
    <Rule xsi:type="RuleCollection" Mode="Or">
        <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
    </Rule>
    <DisableEntityHighlighting>false</DisableEntityHighlighting>
</OfficeApp>